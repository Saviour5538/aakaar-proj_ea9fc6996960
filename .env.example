# Backend database connection string
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database>

# JWT secret for signing tokens
JWT_SECRET=<random secret>

# Backend server port
PORT=8000

# Frontend API URL for connecting to the backend
VITE_API_URL=http://localhost:8000

# OpenAI API key for LLM queries
OPENAI_API_KEY=<your OpenAI API key>

# Anthropic API key for LLM queries
ANTHROPIC_API_KEY=<your Anthropic API key>

# Pinecone API key for vector database (if applicable)
PINECONE_API_KEY=<your Pinecone API key>

# Vector database URL for pgvector
VECTOR_DB_URL=postgresql://<username>:<password>@<host>:<port>/<database>